# NovaDawa API — environment variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database (Neon PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/NovaDawa?sslmode=require

# ── Firebase Auth ───────────────────────────────────────────────────
# Path to your Firebase service account JSON key file
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# Or paste the JSON inline as a single-line string (for Cloud Run / CI):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ── App ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
REQUIRE_AUTH=false           # set true in staging/production
LOG_LEVEL=INFO

# ── Connection pool ─────────────────────────────────────────────────
DB_POOL_MIN=2
DB_POOL_MAX=10
